{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++ file",
            "type": "shell",
            "command": "g++",
            "args": ["-o", "${fileDirname}\\output\\${fileBasenameNoExtension}.exe", "${fileDirname}\\${fileBasename}"],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "Make new folder (for C++)",
            "type": "shell",
            "command": "if (!(Test-Path ${fileDirname}\\output)) {mkdir ${fileDirname}\\output}",
        },
        {
            "label": "Folder maker and builder C++",
            "dependsOn": [
                "Make new folder (for C++)",
                "Build C++ file"
            ]
        }
    ]
}