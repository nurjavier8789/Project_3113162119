{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ Compile and run",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${fileDirname}/output/${fileBasenameNoExtension}.exe",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Folder maker and builder C++"
        },
        {
            "name": "Python run",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}